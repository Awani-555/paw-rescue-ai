PORT=5000
FRONTEND_URL=http://localhost:5173
AI_SERVICE_URL=http://localhost:8001
JWT_SECRET=replace-with-a-long-random-string

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=replace-with-generated-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-generated-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
ALERT_RADIUS_METERS=100

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HELPER_DATA_ENCRYPTION_KEY=replace-with-generated-64-char-hex-key
