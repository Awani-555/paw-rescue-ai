PORT=5000
FRONTEND_URL=http://localhost:5173
AI_SERVICE_URL=http://localhost:8001

# Supabase dashboard -> Project Settings -> Database -> Connection Pooling
# -> Connection string (mode: Transaction). Use the *pooler* host
# (aws-0-<region>.pooler.supabase.com), not the direct db.<ref>.supabase.co
# host - the direct host is IPv6-only and unreachable from many networks.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
# Must match ai-service's INTERNAL_SERVICE_TOKEN (see ai-service/.env.example)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AI_SERVICE_TOKEN=replace-with-generated-64-char-hex-token
JWT_SECRET=replace-with-a-long-random-string

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=replace-with-generated-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-generated-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
ALERT_RADIUS_METERS=100

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HELPER_DATA_ENCRYPTION_KEY=replace-with-generated-64-char-hex-key
